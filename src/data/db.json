  "faqs": [
    {
      "id": "faq-1",
      "question": "What are the requirements to join Kinoo VTC?",
      "answer": "For full programs (KNEC/NITA), you need a KCSE certificate (any grade), National ID or Birth Certificate, and two passport photos. Short courses only require an ID and photos."
    },
    {
      "id": "faq-2",
      "question": "How much are the school fees?",
      "answer": "Thanks to government subsidies, our full-year technical programs cost only KSh 27,000 per year. Short courses range from KSh 8,000 to KSh 15,000."
    },
    {
      "id": "faq-3",
      "question": "Do you offer boarding facilities?",
      "answer": "Currently, Kinoo VTC is a day institution. However, there are numerous affordable student hostels located just a few minutes walking distance from the campus in Kikuyu."
    }
  ],
